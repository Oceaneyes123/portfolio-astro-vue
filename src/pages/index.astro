---
import '@fontsource/poppins';
import { getCollection } from 'astro:content';

import Layout from '../layouts/Layout.astro';
import Stacks from '../layouts/Stacks.astro';
import Experiences from '../layouts/Experiences.astro';
import Portfolio from '../layouts/Portfolio.astro';
import Certificate from '../layouts/Certificate.astro';

import Hero from '../components/Hero.astro';
import Navigation from '../components/Navigation.astro';
import StackCard from '../components/StackCard.astro';
import Timeline from '../components/Timeline.astro';
import Project from '../components/Project.astro';
import ProjectWeb from '../components/ProjectWeb.astro';
import CertificateCard from '../components/CertificateCard.astro';

import picvector from '../img/picvector.png';
import picvector2 from '../img/picvector2.png';

import { certificates, projectImages, stackGroups } from '../data/portfolio';

const projectEntries = await getCollection('projects');
const projects = projectEntries
	.map((entry) => ({ ...entry.data }))
	.sort((a, b) => a.order - b.order);

const androidProjects = projects
	.filter((project) => project.category === 'android')
	.map((project) => ({
		name: project.title,
		details: project.description,
		stacks: project.stack,
		images: (project.imageKeys ?? [])
			.map((key) => projectImages[key as keyof typeof projectImages])
			.filter(Boolean),
	}));

const webProjects = projects
	.filter((project) => project.category === 'web')
	.map((project) => ({
		name: project.title,
		details: project.description,
		stacks: project.stack,
		image: projectImages[project.imageKey as keyof typeof projectImages],
		alt: project.alt,
		url: project.url ?? '#',
	}));

const personalProjects = projects
	.filter((project) => project.category === 'personal')
	.map((project) => ({
		name: project.title,
		details: project.description,
		stacks: project.stack,
		image: projectImages[project.imageKey as keyof typeof projectImages],
		alt: project.alt,
		url: project.url ?? '#',
	}));

const chunkProjects = (items: typeof webProjects, size = 3) =>
	items.reduce((rows, item, index) => {
		if (index % size === 0) rows.push([]);
		rows[rows.length - 1].push(item);
		return rows;
	}, [] as typeof webProjects[]);

const webProjectRows = chunkProjects(webProjects);
const personalProjectRows = chunkProjects(personalProjects);
---

<Layout
	title="Portfolio | Jezrel Dave Sondia"
	metacontent="Jezrel Dave Sondia is a full-stack web developer building web applications, automation tools, and AI-powered products."
>
	<Navigation />
	<main id="home">
		<Hero
			name="Jezrel Dave"
			position="Full Stack Web Developer | AI Enthusiast"
			image={picvector}
			image2={picvector2}
		/>

		<section class="space-y-16 bg-slate-950 px-5 py-16 text-white">
			<div class="mx-auto grid max-w-6xl items-center gap-10 lg:grid-cols-[1.1fr_0.9fr]">
				<div class="overflow-hidden rounded-2xl border border-white/10 bg-black shadow-2xl shadow-slate-950/40">
					<mux-player
						playback-id="lZhaL3h8iXxjXiYqDpr65Iq4pvVeSSMr02lkmZ6JMXk8"
						metadata-video-title="Sign Language Detection Project"
						accent-color="#22d3ee"
						stream-type="on-demand"
						thumbnail-time="34"
						class="featured-video"
					></mux-player>
				</div>

				<div>
					<div class="mb-3 text-sm font-semibold uppercase tracking-[0.25em] text-cyan-300">Featured Project</div>
					<h2 class="text-3xl font-bold leading-tight md:text-5xl">Sign Language Detection</h2>
					<p class="mt-5 max-w-xl text-base leading-8 text-slate-300">
						A machine learning project that detects sign language gestures and translates them into readable output, built to connect real-time computer vision with accessible communication.
					</p>
					<div class="mt-6 flex flex-wrap gap-2">
						<span class="rounded-full bg-cyan-400/10 px-4 py-2 text-sm font-medium text-cyan-200">Machine Learning</span>
						<span class="rounded-full bg-cyan-400/10 px-4 py-2 text-sm font-medium text-cyan-200">Python</span>
						<span class="rounded-full bg-cyan-400/10 px-4 py-2 text-sm font-medium text-cyan-200">Computer Vision</span>
						<span class="rounded-full bg-amber-400/10 px-4 py-2 text-sm font-medium text-amber-200">Accessibility</span>
					</div>
					<a
						href="https://fsl-lens.jezreldave.com/"
						target="_blank"
						rel="noopener noreferrer"
						class="mt-8 inline-flex items-center rounded-lg bg-cyan-400 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300 focus:outline-none focus:ring-4 focus:ring-cyan-300/40"
					>
						Open FSL Lens
						<svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
						</svg>
					</a>
				</div>
			</div>

			<div class="mx-auto grid max-w-6xl items-center gap-10 lg:grid-cols-[0.9fr_1.1fr]">
				<div class="lg:order-2">
					<div class="overflow-hidden rounded-2xl border border-white/10 bg-black shadow-2xl shadow-slate-950/40">
						<iframe
							src="https://world.jezreldave.com/"
							title="3D Car Simulation Game"
							loading="lazy"
							allow="fullscreen; gamepad; accelerometer; gyroscope"
							allowfullscreen
							class="featured-frame"
						></iframe>
					</div>
				</div>

				<div class="lg:order-1">
					<div class="mb-3 text-sm font-semibold uppercase tracking-[0.25em] text-amber-300">Featured Project</div>
					<h2 class="text-3xl font-bold leading-tight md:text-5xl">3D Car Simulation</h2>
					<p class="mt-5 max-w-xl text-base leading-8 text-slate-300">
						A playful Three.js driving experience where visitors can control a car and interact with a small 3D environment directly in the browser.
					</p>
					<div class="mt-6 flex flex-wrap gap-2">
						<span class="rounded-full bg-cyan-400/10 px-4 py-2 text-sm font-medium text-cyan-200">Three.js</span>
						<span class="rounded-full bg-cyan-400/10 px-4 py-2 text-sm font-medium text-cyan-200">3D Web</span>
						<span class="rounded-full bg-cyan-400/10 px-4 py-2 text-sm font-medium text-cyan-200">Interactive Game</span>
						<span class="rounded-full bg-amber-400/10 px-4 py-2 text-sm font-medium text-amber-200">Browser Simulation</span>
					</div>
					<a
						href="https://world.jezreldave.com/"
						target="_blank"
						rel="noopener noreferrer"
						class="mt-8 inline-flex items-center rounded-lg bg-amber-400 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-amber-300 focus:outline-none focus:ring-4 focus:ring-amber-300/40"
					>
						Open Full Experience
						<svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
						</svg>
					</a>
				</div>
			</div>
		</section>

		<Stacks id="stacks">
			{stackGroups.map((group) => (
				<>
					<div class="mb-5 text-xl text-center font-medium text-yellow-400">{group.title}</div>
					<div class="flex flex-wrap justify-center gap-5 mb-10" data-aos="zoom-in" data-aos-duration="1000">
						{group.items.map((stack) => (
							<StackCard
								name={stack.name}
								alt={stack.alt}
								image={stack.image}
								aspectRatio={stack.aspectRatio}
								width={stack.width}
							/>
						))}
					</div>
				</>
			))}
		</Stacks>

		<Experiences id="experiences">
			<Timeline />
		</Experiences>

		<Certificate id="certificates">
			<div class="flex flex-wrap justify-center gap-10">
				{certificates.map((certificate) => (
					<CertificateCard
						title={certificate.title}
						image={certificate.image}
						validityUrl={certificate.validityUrl}
						tag={certificate.tag}
					/>
				))}
			</div>
		</Certificate>

		<div class="bg-black flex flex-col md:flex-row p-10 md:p-16 flex-wrap text-white justify-center gap-20 tracking-widest items-center">
			<div class="text-3xl font-semibold">
				Want to work with me? <br /><span class="bg-clip-text text-6xl text-transparent font-black bg-gradient-to-r from-pink-500 to-violet-500">Hire Me</span>
			</div>
			<div>
				<a href="/contact" class="inline-block px-5 py-3 bg-indigo-600 hover:bg-indigo-800 rounded-lg">Message Me</a>
			</div>
		</div>

		<Portfolio id="portfolio">
			<div class="mb-5 text-xl text-center font-medium text-cyan-700">Android Development</div>
			{androidProjects.map((project) => (
				<div class="flex justify-center text-white text-center mb-10">
					<Project
						name={project.name}
						details={project.details}
						stacks={project.stacks}
						images={project.images}
					/>
				</div>
			))}

			<div class="mb-5 text-xl text-center font-medium text-cyan-700">Web Development</div>
			{webProjectRows.map((row) => (
				<div class="mx-auto mb-8 grid max-w-7xl gap-6 md:grid-cols-2 xl:grid-cols-3">
					{row.map((project) => (
						<ProjectWeb
							name={project.name}
							details={project.details}
							stacks={project.stacks}
							image={project.image}
							alt={project.alt}
							url={project.url}
						/>
					))}
				</div>
			))}

			<div class="mb-5 text-xl text-center font-medium text-cyan-700">Personal Projects</div>
			{personalProjectRows.map((row) => (
				<div class="mx-auto mb-8 grid max-w-7xl gap-6 md:grid-cols-2 xl:grid-cols-3">
					{row.map((project) => (
						<ProjectWeb
							name={project.name}
							details={project.details}
							stacks={project.stacks}
							image={project.image}
							alt={project.alt}
							url={project.url}
						/>
					))}
				</div>
			))}
		</Portfolio>
	</main>
</Layout>

<script>
	import AOS from 'aos';
	import 'aos/dist/aos.css';

	AOS.init({
		once: true,
		duration: 800,
	});
</script>
<script is:inline type="module" src="https://cdn.jsdelivr.net/npm/@mux/mux-player"></script>

<style is:global>
	@font-face {
		font-display: swap;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		font-family: 'Poppins', sans-serif;
	}

	.featured-video {
		aspect-ratio: 16 / 9;
		display: block;
		width: 100%;
	}

	.featured-frame {
		aspect-ratio: 16 / 9;
		border: 0;
		display: block;
		width: 100%;
	}
</style>
