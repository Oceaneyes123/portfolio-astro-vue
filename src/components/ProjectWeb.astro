---
import { Image } from 'astro:assets';

export interface Props {
	name: string;
	details: string;
	stacks: Array<string>;
	image: ImageMetadata;
	alt: string;
	url: string;
}

const { name, details, stacks, image, alt, url } = Astro.props;
const hasUrl = url && url !== '#';
---

<article class="project-card flex h-full flex-col overflow-hidden rounded-2xl bg-slate-950 text-left text-white">
	<div class="project-image" data-aos="zoom-in" data-aos-duration="800" data-aos-anchor-placement="center-bottom">
		<Image
			src={image}
			width={960}
			height={540}
			format="avif"
			alt={alt}
			layout="constrained"
			class="h-full w-full object-cover transition-transform duration-500"
		/>
	</div>

	<div class="flex flex-1 flex-col gap-5 p-6">
		<div>
			<h2 class="text-balance text-2xl font-bold leading-tight">{name}</h2>
			<p class="description mt-3 text-sm leading-6 text-slate-300">{details}</p>
		</div>

		<div class="flex flex-wrap gap-2">
			{stacks.map((stack) => (
				<span class={`rounded-full px-3 py-1 text-xs font-medium ${stack.startsWith('Note:') ? 'bg-amber-400/10 text-amber-200' : 'bg-cyan-400/10 text-cyan-200'}`}>
					{stack}
				</span>
			))}
		</div>

		<details class="project-details text-sm text-slate-200">
			<summary class="cursor-pointer font-medium text-cyan-200">Project details</summary>
			<p class="mt-3 leading-6 text-slate-300">{details}</p>
		</details>

		<div class="mt-auto border-t border-white/10 pt-5">
			{hasUrl ? (
				<a href={url} target="_blank" rel="noopener noreferrer" class="inline-flex w-full items-center justify-center rounded-lg bg-amber-500 px-4 py-3 text-sm font-semibold text-slate-950 transition hover:bg-amber-400 focus:outline-none focus:ring-4 focus:ring-amber-300/40">
					Visit Website
					<svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
					</svg>
				</a>
			) : (
				<span class="inline-flex w-full items-center justify-center rounded-lg bg-white/10 px-4 py-3 text-sm font-semibold text-slate-300">
					Website unavailable
				</span>
			)}
		</div>
	</div>
</article>

<style>
	.project-card {
		box-shadow: 0 18px 40px rgba(15, 23, 42, 0.18);
	}

	.project-card:hover .project-image :global(img) {
		transform: scale(1.04);
	}

	.project-image {
		aspect-ratio: 16 / 9;
		background: #e5e7eb;
		overflow: hidden;
	}

	.description {
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.project-details summary {
		list-style: none;
	}

	.project-details summary::-webkit-details-marker {
		display: none;
	}

	.project-details summary::before {
		content: '+';
		display: inline-block;
		margin-right: 0.5rem;
		transition: transform 0.2s ease;
	}

	.project-details[open] summary::before {
		transform: rotate(45deg);
	}
</style>
