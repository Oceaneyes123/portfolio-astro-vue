---
import { Image } from 'astro:assets';

export interface Props {
	name: string;
	details: string;
	stacks: Array<string>;
	images: Array<ImageMetadata>;
}

const { name, details, stacks, images } = Astro.props as Props;
---

<article class="bg-gray-900 p-5 md:w-9/12 rounded-3xl card">
	<div class="flex flex-col md:flex-row text-left">
		<div class="md:w-1/2 w-full mx-auto mb-5">
			<h2 class="text-2xl font-bold mb-5">{name}</h2>
			<p class="mb-10">{details}</p>
			<div class="font-medium">Stacks Used</div>
			<ul class="pl-5">{stacks.map((stack) => <li>- {stack}</li>)}</ul>
		</div>
		<div class="md:w-1/2 w-full mx-auto">
			<div class="flex flex-wrap gap-5 justify-center">
				{images.map((image, index) => (
					<div class="w-12/12 md:w-2/12" data-aos="fade-up">
						<Image
							src={image}
							width={400}
							height={800}
							alt={`${name} app screen ${index + 1}`}
							format="avif"
							layout="constrained"
						/>
					</div>
				))}
			</div>
		</div>
	</div>
</article>

<style>
	.card {
		--elevation: 5;
		--epx: calc(var(--elevation) * 1px);
		--shadow1: 0 0 1px rgba(0, 0, 0, 0.1);
		--shadow2: 0 1px 2px rgba(0, 0, 0, 0.08);
		--offset-y: calc(var(--epx) + 1px);
		--blur: calc(var(--epx) * 2);
		--spread: calc(var(--epx) * 0.3);
		--shadow3: 0 var(--offset-y) var(--blur) var(--spread) rgba(0, 0, 0, 0.2);

		box-shadow: var(--shadow1), var(--shadow2), var(--shadow3);
	}
</style>
